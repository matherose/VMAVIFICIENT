# vmavificient runtime configuration
#
# The recommended way to create this file is the one-shot interactive
# setup, which prompts for both fields and writes them with 0600
# permissions:
#
#     vmavificient --config
#
# It writes to $HOME/.config/vmavificient/config.ini directly. Use this
# example only if you'd rather edit the INI by hand.
#
# Search order (first hit wins):
#   1. $HOME/.config/vmavificient/config.ini  (primary; --config writes here)
#   2. ./config.ini                            (legacy dev fallback)
#
# Lines beginning with '#' or ';' are comments. Sections (e.g. [foo]) are
# ignored — keys are global.

# TMDB v3 API key (https://www.themoviedb.org/settings/api).
tmdb_api_key =

# Release group tag appended to the output filename, e.g.
#   Title.YEAR.....OPUS-<release_group>.mkv
release_group = matherose
