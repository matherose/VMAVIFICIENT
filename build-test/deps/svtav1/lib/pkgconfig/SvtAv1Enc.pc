prefix=/Volumes/Data/MEDIAS/MOVIE/VMAVIFICIENT/build-test/deps/svtav1
exec_prefix=${prefix}
includedir=${prefix}/include
libdir=${exec_prefix}/lib

Name: SvtAv1Enc
Description: SVT (Scalable Video Technology) for AV1 encoder library
Version: 4.0.1
Requires.private: 
Libs: -L${libdir} -lSvtAv1Enc
Libs.private: 
Cflags: -I${includedir}/svt-av1 -DRTC_BUILD=0
Cflags.private: -UEB_DLL
