---
# clang-tidy configuration — enforced by the clang-tidy CI job (build.yml)
# and the pre-commit clang-tidy-changed hook. Policy: all findings are
# errors (zero-findings gate), except readability-function-size which is
# advisory-only (see WarningsAsErrors note below).
# NASA Power of Ten enforcement: recursion check ON, return-value check ON,
# strcpy check ON.
# clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling is
# OFF: it demands C11 Annex K *_s functions that do not exist on macOS or
# glibc, so every fprintf/memcpy call would need a NOLINT.

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  misc-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-multi-level-implicit-pointer-conversion,
  -bugprone-assignment-in-if-condition,
  -misc-include-cleaner,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -readability-braces-around-statements,
  -readability-isolate-declaration,
  -readability-math-missing-parentheses,
  -cert-msc30-c,
  -cert-msc50-cpp,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling

# All warnings are errors — no silent passes — EXCEPT function-size:
# 35 pre-existing functions exceed the Power-of-Ten budget (v2.1 refactor
# debt); the check stays on as an advisory warning so new offenders are
# visible in CI logs without failing the gate.
WarningsAsErrors: '*,-readability-function-size'

# Only lint headers under include/ and src/ — not third-party or system
# headers. Paths in diagnostics are absolute, so the pattern must not be
# anchored to the start of the string.
HeaderFilterRegex: '.*/(include|src)/.*\.h$'

# Use the project .clang-format file for any formatting decisions
FormatStyle: file

CheckOptions:
  # --- Naming conventions ---
  # Functions/variables/parameters: snake_case
  # Typedefs (structs, enums): PascalCase — the project-wide convention
  # (MediaInfo, PipelineCtx, StageStatus, ...)
  # Macros and enum constants: UPPER_CASE
  # File-scope constants: either UPPER_CASE or snake_case (both in use)

  - key: readability-identifier-naming.FunctionCase
    value: lower_case

  - key: readability-identifier-naming.VariableCase
    value: lower_case

  - key: readability-identifier-naming.ParameterCase
    value: lower_case

  - key: readability-identifier-naming.LocalVariableCase
    value: lower_case

  - key: readability-identifier-naming.GlobalVariableCase
    value: lower_case

  - key: readability-identifier-naming.GlobalConstantCase
    value: aNy_CasE

  # Struct tags: either snake_case or matching their PascalCase typedef
  - key: readability-identifier-naming.StructCase
    value: aNy_CasE

  # Enum tags: snake_case
  - key: readability-identifier-naming.EnumCase
    value: lower_case

  # Enum constants: UPPER_CASE
  - key: readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE

  # Typedefs: PascalCase (clang-tidy calls this CamelCase)
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase

  # Macros: UPPER_CASE
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE

  # --- NASA Power of Ten enforcement options ---

  # Rule 4: function length — clang-tidy does not directly enforce line count;
  # use readability-function-size for complexity budget instead
  - key: readability-function-size.LineThreshold
    value: '60'
  - key: readability-function-size.StatementThreshold
    value: '50'
  - key: readability-function-size.BranchThreshold
    value: '10'
  - key: readability-function-size.NestingThreshold
    value: '4'

  # Suppress false-positives from cert-err33-c on well-known void-returning funcs
  # Add per-site with: // NOLINT(cert-err33-c): <reason>
