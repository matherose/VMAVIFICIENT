{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug build with full warnings and sanitizers enabled",
      "description": "Debug build with -std=c11 -pedantic-errors and hardening flags per AGENTS.md § 8.2",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS": "-std=c11 -pedantic-errors -Wall -Wextra -Werror -Wshadow -Wstrict-prototypes -Wmissing-prototypes -Wmissing-declarations -Wundef -Wconversion -Wsign-conversion -Wformat=2 -Wformat-security -Wnull-dereference -Wdouble-promotion -Wfloat-conversion -fno-common -fno-omit-frame-pointer -fstack-protector-strong -fstack-clash-protection -D_FORTIFY_SOURCE=3 -fno-strict-overflow"
      }
    },
    {
      "name": "asan",
      "inherits": "debug",
      "displayName": "ASan + UBSan build",
      "description": "AddressSanitizer + UndefinedBehaviorSanitizer build per AGENTS.md § 8.2",
      "cacheVariables": {
        "CMAKE_C_FLAGS_INIT": "-fsanitize=address,undefined -fno-sanitize-recover=all",
        "VMAV_SANITIZE": "ON"
      }
    },
    {
      "name": "msan",
      "inherits": "debug",
      "displayName": "MSan build",
      "description": "MemorySanitizer build per AGENTS.md § 8.2 (mutually exclusive with ASan)",
      "cacheVariables": {
        "CMAKE_C_FLAGS_INIT": "-fsanitize=memory -fno-sanitize-recover=all -O1",
        "VMAV_SANITIZE": "ON"
      }
    },
    {
      "name": "tsan",
      "inherits": "debug",
      "displayName": "TSan build",
      "description": "ThreadSanitizer build per AGENTS.md § 8.2 (mutually exclusive with ASan/MSan)",
      "cacheVariables": {
        "CMAKE_C_FLAGS_INIT": "-fsanitize=thread -fno-sanitize-recover=all",
        "VMAV_SANITIZE": "ON"
      }
    },
    {
      "name": "coverage",
      "inherits": "debug",
      "displayName": "Coverage build",
      "description": "Coverage instrumentation build per AGENTS.md § 8.2",
      "cacheVariables": {
        "CMAKE_C_FLAGS_INIT": "-fprofile-instr-generate -fcoverage-mapping"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release build",
      "description": "Release build with -O2 and optimizations per AGENTS.md § 8.2",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "-std=c11 -pedantic-errors -Wall -Wextra -Werror -O2 -fstack-protector-strong -D_FORTIFY_SOURCE=2 -fvisibility=hidden -flto"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "msan",
      "configurePreset": "msan"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "msan",
      "configurePreset": "msan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
