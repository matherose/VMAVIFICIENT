{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
    "configurePresets": [
        {
            "name": "host",
            "displayName": "Native host build (Clang)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/host",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "VMAV_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "debug",
            "inherits": "host",
            "displayName": "Debug build with ASan + UBSan",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "VMAV_SANITIZE": "ON",
                "VMAV_LTO": "OFF"
            }
        },
        {
            "name": "linux-x86_64-musl",
            "displayName": "Linux x86_64 musl (zig cc cross)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/linux-x86_64-musl",
            "toolchainFile": "${sourceDir}/cmake/toolchains/linux-x86_64-musl.cmake",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "linux-aarch64-musl",
            "displayName": "Linux aarch64 musl (zig cc cross)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/linux-aarch64-musl",
            "toolchainFile": "${sourceDir}/cmake/toolchains/linux-aarch64-musl.cmake",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "macos-x86_64",
            "displayName": "macOS x86_64 (Apple Clang)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/macos-x86_64",
            "toolchainFile": "${sourceDir}/cmake/toolchains/macos-x86_64.cmake",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "macos-arm64",
            "displayName": "macOS arm64 (Apple Clang)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/macos-arm64",
            "toolchainFile": "${sourceDir}/cmake/toolchains/macos-arm64.cmake",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "windows-x86_64-mingw",
            "displayName": "Windows x86_64 (llvm-mingw cross)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-x86_64-mingw",
            "toolchainFile": "${sourceDir}/cmake/toolchains/windows-x86_64-mingw.cmake",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        }
    ],
    "buildPresets": [
        { "name": "host",                 "configurePreset": "host" },
        { "name": "debug",                "configurePreset": "debug" },
        { "name": "linux-x86_64-musl",    "configurePreset": "linux-x86_64-musl" },
        { "name": "linux-aarch64-musl",   "configurePreset": "linux-aarch64-musl" },
        { "name": "macos-x86_64",         "configurePreset": "macos-x86_64" },
        { "name": "macos-arm64",          "configurePreset": "macos-arm64" },
        { "name": "windows-x86_64-mingw", "configurePreset": "windows-x86_64-mingw" }
    ],
    "testPresets": [
        {
            "name": "host",
            "configurePreset": "host",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": { "outputOnFailure": true }
        }
    ]
}
