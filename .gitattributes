# Default: text files normalized to LF on commit, native on checkout
* text=auto eol=lf

# Source code is always LF
*.c     text eol=lf
*.h     text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.cmake text eol=lf
*.sh    text eol=lf
CMakeLists.txt text eol=lf

# Windows-only build scripts stay CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary fixtures must not be touched
*.mkv   binary
*.sup   binary
*.bin   binary
*.png   binary
*.jpg   binary
*.wav   binary
*.zst   binary
