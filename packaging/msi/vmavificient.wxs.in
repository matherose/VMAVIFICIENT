<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4/v5 source for the vmavificient Windows installer.

  Tokens substituted by build_msi.sh at install time:
    @VERSION@   - VERSION file contents (e.g. 2.0.0-dev)
    @STAGE@     - absolute path to the staging directory containing
                  the cmake install layout. WiX resolves File@Source
                  relative to its own working dir, so the stage path
                  has to be embedded into each File@Source as an
                  absolute path. The build script handles this.

  UpgradeCode is pinned - it must stay stable across versions so that
  Windows recognizes upgrades. Do not change it without also bumping
  ProductCode (which is autogenerated by the * in Package@Id).

  Layout pattern: a single StandardDirectory > Directory tree for
  INSTALLFOLDER under %ProgramFiles%, plus Component-level
  `Subdirectory` attributes to land tessdata + doc files in nested
  paths. This is the WiX v4+ idiom and avoids the WIX0389
  "not a relative path" rejection that nested `<Directory>` elements
  under StandardDirectory trigger with v4.0.5 / v5.0.2.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="vmavificient"
           Manufacturer="VMAVIFICIENT contributors"
           Version="@VERSION@"
           UpgradeCode="F408530A-6F11-4238-A6EA-D78C9BF5F435"
           Scope="perMachine"
           Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version of vmavificient is already installed."/>
    <MediaTemplate EmbedCab="yes"/>

    <Feature Id="Main" Title="vmavificient" Level="1">
      <ComponentGroupRef Id="Vmav.Components"/>
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="vmavificient"/>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="Vmav.Components" Directory="INSTALLFOLDER">
      <!--
        Main binary. Includes both env-var writes (PATH + TESSDATA_PREFIX)
        because the tessdata resolver in subtitle_convert.c only knows
        POSIX paths; on Windows we set TESSDATA_PREFIX explicitly so
        Tesseract finds the bundled eng.traineddata regardless of where
        the binary is invoked from.
      -->
      <Component Id="MainExe" Bitness="always64">
        <File Source="@STAGE@/bin/vmavificient.exe" KeyPath="yes"/>
        <Environment Id="AddToPath"
                     Name="PATH"
                     Action="set"
                     System="yes"
                     Part="last"
                     Value="[INSTALLFOLDER]"/>
        <Environment Id="TessdataPrefix"
                     Name="TESSDATA_PREFIX"
                     Action="set"
                     System="yes"
                     Value="[INSTALLFOLDER]tessdata"/>
      </Component>

      <!--
        Tessdata + doc files are laid out under subdirectories of
        INSTALLFOLDER via the `Subdirectory` attribute. Each Component
        lands at INSTALLFOLDER\<Subdirectory>\<file>.
      -->
      <Component Id="Tessdata" Subdirectory="tessdata" Bitness="always64">
        <File Source="@STAGE@/share/vmavificient/tessdata/eng.traineddata"
              KeyPath="yes"/>
      </Component>

      <Component Id="DocLicense" Subdirectory="doc" Bitness="always64">
        <File Source="@STAGE@/share/doc/vmavificient/LICENSE"
              KeyPath="yes"/>
      </Component>
      <Component Id="DocLicenseBinary" Subdirectory="doc" Bitness="always64">
        <File Source="@STAGE@/share/doc/vmavificient/LICENSE-BINARY"
              KeyPath="yes"/>
      </Component>
      <Component Id="DocReadme" Subdirectory="doc" Bitness="always64">
        <File Source="@STAGE@/share/doc/vmavificient/README.md"
              KeyPath="yes"/>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
