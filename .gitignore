# Build output
/build/
/build-*/
/cmake-build-*/
/out/

# Toolchains fetched by scripts/
/.toolchains/
/.zig/
/.llvm-mingw/

# Third-party install prefix (set by ExternalProject)
/third_party_install/

# IDE
.vscode/
.idea/
*.code-workspace
.cache/
compile_commands.json

# macOS
.DS_Store

# Editor temp
*.swp
*~
\#*\#
.#*

# Test artifacts
/Testing/
/CTestTestfile.cmake
/CMakeCache.txt
/CMakeFiles/

# Coverage
*.gcda
*.gcno
*.profraw
*.profdata
/coverage/

# Release artifacts (local builds)
*.deb
*.pkg
*.msi
*.tar.zst
/dist/

# Logs / scratch
*.log
/tmp/

# OpenSSL's perl Configure script dumps these into CWD; ensure stray
# runs (debugging from worktree root) never get committed.
/Makefile
/Makefile.in
/configdata.pm
/include/openssl/

# ===================================================================
# Media files: validation sources, encode outputs, sidecars.
# Never committed to the repo; they live in the worktree as user
# convenience but should never accidentally land in git.
#
# tests/fixtures/ is fine because its only inputs are generated by
# tests/fixtures/fixturegen.c into build/<preset>/tests/fixtures/,
# already covered by the /build/ rule above.
# ===================================================================

# Container formats
*.mkv
*.mp4
*.mov
*.avi
*.webm
*.m4v
*.ts
*.m2ts
*.mts
*.vob
*.wmv
*.flv
*.mpg
*.mpeg
*.3gp

# Raw / intermediate video
*.y4m
*.yuv
*.raw
*.ivf
*.rpu.bin

# Audio (encoder outputs + source extractions)
*.opus
*.mp3
*.aac
*.ac3
*.eac3
*.dts
*.flac
*.wav
*.m4a
*.thd
*.truehd

# Subtitle sidecars
*.srt
*.sup
*.ass
*.ssa
*.vtt
*.idx
*.sub

# Resume-state cache (default `<input-dir>/.vmavificient-cache` and
# any explicit --cache-dir landing inside the worktree).
.vmavificient-cache/
**/.vmavificient-cache/

# Phase 8 real-content fixtures (Big Buck Bunny, Tears of Steel HDR).
# Sources are fetched on demand by scripts/fetch_real_content.sh —
# never committed because they're large and trivially re-downloaded.
/tests/fixtures/.real-content-cache/

# Phase 9 tessdata cache (eng.traineddata ~22 MB) used by packaging.
# Same not-in-repo policy: fetched by scripts/fetch_tessdata.sh on
# demand, gitignored, cached in CI by sha-pin.
/tests/fixtures/.tessdata-cache/
